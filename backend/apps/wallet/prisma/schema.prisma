generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Int
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("transactions")
}
